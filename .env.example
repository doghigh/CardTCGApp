# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...
EBAY_APP_ID=YourEbayAppId-here
EBAY_CERT_ID=YourEbayCertId-here

# eBay webhook (used by ebay_webhook/main.py deployed on Render)
EBAY_VERIFICATION_TOKEN=your-random-secret-32-chars-minimum
EBAY_ENDPOINT_URL=https://your-app.onrender.com/ebay/deletion

# Optional: keep app data (db, scans, config, logs) in a fixed folder instead of
# %APPDATA%/Lorebox. Recommended when running under Microsoft Store Python, whose
# %APPDATA% is virtualized into a disposable per-package cache.
# LOREBOX_DATA_DIR=C:\Users\you\LoreBox-Data
